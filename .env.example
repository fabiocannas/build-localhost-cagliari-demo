# Porta del server webhook locale
PORT=4000

# Secret condiviso con il webhook GitHub (HMAC sha256). Imposta lo stesso valore su GitHub.
WEBHOOK_SECRET=changeme-supersecret

# (Opzionale) URL del canale smee.io usato come tunnel verso localhost durante il demo
SMEE_URL=

# Dimensioni della finestra della mascotte (px)
WINDOW_WIDTH=320
WINDOW_HEIGHT=320

# Avvia la mascotte in modalità click-through (1 = i click passano sotto la finestra)
CLICK_THROUGH=0
